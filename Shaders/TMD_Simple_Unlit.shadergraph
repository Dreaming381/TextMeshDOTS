    "m_ObjectId": "cc7fbe14cd164f4482f3b47387a3fc93",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ScreenSpaceRatio (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1692.0,
            "y": 1731.0,
            "width": 259.0,
            "height": 142.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "709430db202d4aaa93410ed162219dd9"
        },
        {
            "m_Id": "cd1623bb6c1141aeb5940be50614a1ec"
        },
        {
            "m_Id": "4d4ea14484bc4343baace1c6f58acbca"
        },
        {
            "m_Id": "09a42d88cb244f00a5d8df02733e136f"
        }
    ],
    "synonyms": [],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ScreenSpaceRatio",
    "m_FunctionSource": "c02aab30a23b76e4b9bf303e29bc8e4a",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "if(Filter)\r\n\t{\r\n\t\tfloat2 a = float2(ddx(UV.x), ddy(UV.x));\r\n\t\tfloat2 b = float2(ddx(UV.y), ddy(UV.y));\r\n\t\tfloat s = lerp(dot(a,a), dot(b,b), 0.5);\r\n\t\tSSR = rsqrt(s) / TextureSize;\r\n\t}\r\n\telse\r\n\t{\r\n\t\tfloat s = rsqrt(abs(ddx(UV.x) * ddy(UV.y) - ddy(UV.x) * ddx(UV.y)));\r\n\t\tSSR = s / TextureSize;\r\n\t}"
}

