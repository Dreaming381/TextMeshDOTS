    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "a483a0b57c3a4cc6a4a1ab4123b8befe",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ComputeSDF (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1315.9998779296875,
            "y": 1399.9998779296875,
            "width": 206.9998779296875,
            "height": 190.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "e21a0b53d605476681ce1962abcc5e7b"
        },
        {
            "m_Id": "730b8ff7020d45d28f4eeba727d09707"
        },
        {
            "m_Id": "71314070b3bd4b3998625763576a3aac"
        },
        {
            "m_Id": "c465d151d44345408b40480804a5a445"
        },
        {
            "m_Id": "5a016052b8174e74b35c59ebe889ac37"
        },
        {
            "m_Id": "0988300870a44e3fad13096ba01dfc10"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ComputeSDF",
    "m_FunctionSource": "c02aab30a23b76e4b9bf303e29bc8e4a",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "softness *= SSR * SDR;\r\n\tfloat d = (SD - 0.5) * SDR;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t// Signed distance to edge, in Texture space\r\n\toutAlpha = saturate((d * 2.0 * SSR + 0.5 + isoPerimeter * SDR * SSR + softness * 0.5) / (1.0 + softness));\t// Screen pixel coverage (alpha)"
}

